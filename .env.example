# StepClaw local proxy settings (from 阶跃AI桌面伙伴)
# These are auto-detected defaults - you usually don't need to change them
STEPCLAW_BASE_URL=http://127.0.0.1:3199/v1
STEPCLAW_API_KEY=stepfun-model-proxy
STEPCLAW_DEFAULT_MODEL=step-alpha

# Proxy server port (OpenCode connects to this)
PORT=8080

# Log level: debug | info | warn | error
LOG_LEVEL=info
